{
  "name": "terra-viva-inventory-viewer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "setup:drive-oauth": "node scripts/setup-drive-oauth.mjs",
    "stage:approved-catalog": "node scripts/stage-approved-catalog.mjs",
    "publish:catalog": "node scripts/publish-catalog.mjs",
    "process:catalog-draft": "node scripts/publish-catalog.mjs --workflow draft",
    "watch:drive-orders": "node scripts/process-drive-orders.mjs --once false"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3"
  }
}
